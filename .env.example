# ============================================================
#  CyberForge Range Control Deck — Environment Configuration
# ============================================================
#
#  Copy this file to ".env" and fill in your real values.
#
#    cp .env.example .env
#
#  Variables set in your actual shell environment always take
#  priority over this file (python-dotenv does NOT override).
#
#  Run server after configuring:
#    uvicorn cyberforge.main:app --reload
# ============================================================


# ------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------

# Development (SQLite — no setup needed):
CYBERFORGE_DATABASE_URL=sqlite+pysqlite:///./cyberforge.db

# Production (PostgreSQL — recommended):
# CYBERFORGE_DATABASE_URL=postgresql+psycopg://cyberforge:your_password@localhost:5432/cyberforge

# Repository backend: sqlalchemy (default) | memory (unit tests only)
CYBERFORGE_REPOSITORY=sqlalchemy


# ------------------------------------------------------------
# PROVISIONER MODE
# ------------------------------------------------------------
#
# Choose ONE of: ssh | docker | virtualbox | mock
#
#   ssh         — Deploy challenges on real remote Linux machines via SSH.
#                 Best for: Production with dedicated physical/virtual machines.
#
#   docker      — Clone challenge from GitLab and start via docker compose
#                 on the LOCAL machine. No separate VMs needed.
#                 Best for: Single-server setups with Docker installed.
#
#   virtualbox  — Clone template VMs via VBoxManage, start headless,
#                 fetch real IP from Guest Additions.
#                 Best for: Full isolated lab environments.
#
#   mock        — Instant fake IPs. For automated tests ONLY.
#                 DO NOT use in production.
#
CYBERFORGE_PROVISIONER=mock


# ------------------------------------------------------------
# GITLAB CONTENT REPOSITORY
# (Required for SSH and Docker provisioner modes)
# ------------------------------------------------------------

# Your GitLab repo containing challenge content directories
CYBERFORGE_GITLAB_REPO_URL=https://gitlab.example.com/your-org/cyberforge-content.git

# GitLab Personal Access Token (scope: read_repository)
# Generate at: GitLab → User Settings → Access Tokens
CYBERFORGE_GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx


# ------------------------------------------------------------
# SSH PROVISIONER SETTINGS
# (Only needed when CYBERFORGE_PROVISIONER=ssh)
# ------------------------------------------------------------

# IP or hostname of the TARGET machine (where challenges are hosted)
CYBERFORGE_TARGET_HOST=192.168.1.100

# SSH user on the target machine (needs sudo or root)
CYBERFORGE_TARGET_USER=root

# SSH port (default: 22)
CYBERFORGE_TARGET_PORT=22

# Path to your SSH private key (leave empty to use SSH agent / default key)
CYBERFORGE_SSH_IDENTITY_FILE=/home/youruser/.ssh/cf_id_rsa

# IP or hostname of the ATTACKER machine (separate from target)
# Leave empty to use the same host as TARGET
CYBERFORGE_ATTACKER_HOST=192.168.1.101


# ------------------------------------------------------------
# DOCKER PROVISIONER SETTINGS
# (Only needed when CYBERFORGE_PROVISIONER=docker)
# ------------------------------------------------------------

# Local directory where challenge repos are cloned
CYBERFORGE_DOCKER_WORKDIR=/opt/cyberforge

# TCP port that challenge web services will listen on (default: 8080)
CYBERFORGE_DOCKER_SERVICE_PORT=8080


# ------------------------------------------------------------
# VIRTUALBOX PROVISIONER SETTINGS
# (Only needed when CYBERFORGE_PROVISIONER=virtualbox)
# ------------------------------------------------------------

# Name of your pre-created attacker template VM in VirtualBox
CYBERFORGE_VBOX_ATTACKER_TEMPLATE=cf-attacker-template

# Name of your pre-created target template VM in VirtualBox
CYBERFORGE_VBOX_TARGET_TEMPLATE=cf-target-template

# Dry run mode: true = simulate VBoxManage calls, false = real VM provisioning
# Set to false only when VMs are configured and ready
CYBERFORGE_VBOX_DRY_RUN=true


# ------------------------------------------------------------
# CONTENT CATALOG VALIDATION
# (Optional — enable in production for integrity checks)
# ------------------------------------------------------------

# Path to a local mirror of the GitLab content repository
# Used ONLY for structure validation at server startup
CYBERFORGE_CONTENT_ROOT=

# Enable content structure validation at startup (true | false)
# Checks that each challenge has setup.sh, teardown.sh etc.
CYBERFORGE_VALIDATE_CONTENT_STRUCTURE=false
